# A delta-less bug (no specs/ delta at all) archives with no fold: exactly
# one ledger record, capability-less (spec-lifecycle.md §8/errata 9).

env HOME=/no-home

exec lifecycle archive 007-fix-panic --format json
stdout '"capability": ""'
stdout '"deltaOps": \[\]'
stdout '"records"'

! exists openspec/specs
exists openspec/changes/archive/007-fix-panic/proposal.md

-- lifecycle.yml --
schemaVersion: 1
consentPolicy: off

-- openspec/changes/007-fix-panic/proposal.md --
---
issue: "kentra-io/kafka-dq#7"
type: bug
---

